{
  "name": "mathmodel-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop agent for mathematical modeling contests and research writing.",
  "main": "desktop/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:ui\" \"npm:dev:electron\"",
    "dev:ui": "vite --config frontend/vite.config.ts --host 127.0.0.1 --port 5179",
    "dev:electron": "wait-on http://127.0.0.1:5179 && cross-env MMA_DEV_SERVER_URL=http://127.0.0.1:5179 electron desktop/main.js",
    "build:ui": "vite build --config frontend/vite.config.ts",
    "start": "electron desktop/main.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "wait-on": "^8.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}

